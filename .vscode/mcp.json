{
  "servers": {
    "weather": {
      "command": "uv",
      "args": ["--directory", "./weather-mcp", "run", "weather.py"]
    },
    "docker-weather": {
      "command": "sudo",
      "args": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--init",
        "-e",
        "DOCKER_CONTAINER=true",
        "mcp-weather"
      ]
    },
    "shell": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "./shell-mcp", "run", "server.py"]
    },
    "docker-shell": {
      "command": "sudo",
      "args": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--init",
        "-e",
        "DOCKER_CONTAINER=true",
        "shellserver-app"
      ]
    },
    "research-prompt-mcp": {
      "url":"http://127.0.0.1:8000/mcp/"
    }
  }
}
